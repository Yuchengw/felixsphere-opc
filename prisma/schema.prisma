generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Models ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  companies    Company[]
  chatMessages ChatMessage[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Business Models ────────────────────────────────────────

model Company {
  id               String   @id @default(cuid())
  userId           String
  name             String
  slug             String   @unique
  jurisdictionCode String
  entityType       String
  status           String   @default("DRAFT")
  description      String?
  industry         String?
  foundedDate      DateTime?
  founderDetails   String?
  setupCurrentStep Int      @default(0)
  setupCompleted   Boolean  @default(false)
  setupData        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]
  milestones   Milestone[]
  chatSessions ChatSession[]
  documents    Document[]

  @@index([userId])
  @@map("companies")
}

model Task {
  id               String    @id @default(cuid())
  companyId        String
  title            String
  description      String?
  status           String    @default("PENDING")
  category         String
  stage            String
  priority         Int       @default(0)
  dueDate          DateTime?
  completedAt      DateTime?
  sortOrder        Int       @default(0)
  checklistItemKey String?
  resourceUrl      String?
  resourceLabel    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, stage])
  @@map("tasks")
}

model Milestone {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  description String?
  stage       String
  status      String    @default("LOCKED")
  sortOrder   Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("milestones")
}

model Document {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  description String?
  templateKey String
  status      String    @default("PENDING")
  fileUrl     String?
  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("documents")
}

// ─── AI Agent Chat Models ────────────────────────────────────────

model ChatSession {
  id        String   @id @default(cuid())
  companyId String
  agentRole String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([companyId])
  @@index([companyId, agentRole])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String   @id @default(cuid())
  chatSessionId String
  userId        String?
  role          String
  content       String
  tokenCount    Int?
  modelUsed     String?
  createdAt     DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id])

  @@index([chatSessionId])
  @@map("chat_messages")
}
